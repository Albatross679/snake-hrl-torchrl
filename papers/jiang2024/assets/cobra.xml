<mujoco model="cobra_snake_navigation">
    <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>

    <option integrator="Euler" timestep="0.001">
        <flag energy="enable" clampctrl="enable"/>
    </option>

    <size nconmax="2000"/>

    <default>
        <geom conaffinity="0" condim="3" friction="1 0.05 0.00001" margin="0.01" density="600"/>
        <joint armature="0.001" damping="0" frictionloss="0.001"/>

        <default class="wheel">
            <joint axis="0 1 0" type="hinge" damping="0.2"/>
            <geom type="cylinder" fromto="0 0 0  0 0.025 0" size="0.05" material="geom"
                  rgba=".9 .9 .9 1" friction="1.25 1.0 0.0001"/>
        </default>

        <!-- Yaw joints: rotate around z-axis -->
        <default class="yaw_joint">
            <geom material="geom" rgba="0.8 0.7 .6 1"/>
            <joint pos="0 0 0" axis="0 0 1" type="hinge" limited="true" range="-90 90"/>
        </default>

        <!-- Pitch joints: rotate around y-axis -->
        <default class="pitch_joint">
            <geom material="geom" rgba="0.7 0.8 .6 1"/>
            <joint pos="0 0 0" axis="0 1 0" type="hinge" limited="true" range="-45 45"/>
        </default>

        <position ctrllimited="true" ctrlrange="-1.5 1.5" forcelimited="true"
                  forcerange="-20.0 20.0" kp="20" gear="1"/>
    </default>

    <asset>
        <texture builtin="gradient" height="100" rgb1="1 1 1" rgb2="0 0 0" type="skybox" width="100"/>
        <texture builtin="flat" height="1278" mark="cross" markrgb="1 1 1" name="texgeom" random="0.01"
                 rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" type="cube" width="127"/>
        <texture builtin="checker" height="100" name="texplane" rgb1="0 0 0" rgb2="0.8 0.8 0.8"
                 type="2d" width="100"/>
        <material name="MatPlane" reflectance="0.5" shininess="1" specular="1"
                  texrepeat="80 80" texture="texplane"/>
        <material name="geom" texture="texgeom" texuniform="true"/>
        <material name="MatTarget" rgba="0 1 0 1" reflectance="0.05" shininess="0.1" specular="0.1"/>
    </asset>

    <visual>
        <map znear="0.0625"/>
        <quality shadowsize="4096"/>
    </visual>

    <worldbody>
        <light cutoff="100" diffuse="1 1 1" dir="0 0 -1.3" directional="true" exponent="1"
               pos="0 0 1.3" specular=".1 .1 .1"/>
        <geom name="floor" size="80 80 10" material="MatPlane" conaffinity="1" condim="3"
              pos="0 0 -0.1" rgba="0.8 0.9 0.8 1" type="plane"/>

        <!-- Waypoint marker -->
        <body name="waypoint" pos="0 0 0.1">
            <joint axis="1 0 0" name="waypoint_slider_x" type="slide"/>
            <joint axis="0 1 0" name="waypoint_slider_y" type="slide"/>
            <geom name="waypoint_geom" type="sphere" pos="0 0 0" size="0.15"
                  material="MatTarget" conaffinity="0" contype="0"/>
        </body>

        <!-- COBRA snake robot: head + 11 alternating pitch/yaw joints + tail -->
        <body name="link0" pos="0 0 0.0">
            <!-- Free body DOFs -->
            <joint axis="1 0 0" name="slider_x" type="slide"/>
            <joint axis="0 1 0" name="slider_y" type="slide"/>
            <joint axis="0 0 1" name="slider_z" type="slide"/>
            <joint pos="0 0 0" axis="1 0 0" name="hinge_x" type="hinge"/>
            <joint pos="0 0 0" axis="0 1 0" name="hinge_y" type="hinge"/>
            <joint pos="0 0 0" axis="0 0 1" name="hinge_z" type="hinge"/>

            <!-- Head module -->
            <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_00"/><geom/></body>
            <geom name="head" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box" material="geom"
                  rgba="0.8 0.7 .6 1"/>
            <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
            <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_00"/><geom/></body>

            <site name="site_head" pos="-0.175 0 0.0" type="box" size=".01 .01 .01"/>
            <camera name="head_cam" mode="fixed" pos="0 0 0.025" fovy="90" euler="90 -90 0"/>
            <camera name="track_snake" mode="trackcom" pos="0 -4 6" euler="30 0 0"/>
            <camera name="top_down" mode="trackcom" pos="0 0 8" euler="0 0 0"/>

            <!-- Joint 01: yaw (z-axis) — odd joint index=1, but first joint -->
            <body name="link1" pos="-0.35 0 0" childclass="yaw_joint">
                <joint name="joint01"/>
                <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_01"/><geom/></body>
                <geom name="link1_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"/>
                <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_01"/><geom/></body>

                <!-- Joint 02: pitch (y-axis) -->
                <body name="link2" pos="-0.35 0 0" childclass="pitch_joint">
                    <joint name="joint02"/>
                    <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_02"/><geom/></body>
                    <geom name="link2_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"/>
                    <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                    <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_02"/><geom/></body>

                    <!-- Joint 03: yaw -->
                    <body name="link3" pos="-0.35 0 0" childclass="yaw_joint">
                        <joint name="joint03"/>
                        <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_03"/><geom/></body>
                        <geom name="link3_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"/>
                        <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                        <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_03"/><geom/></body>

                        <!-- Joint 04: pitch -->
                        <body name="link4" pos="-0.35 0 0" childclass="pitch_joint">
                            <joint name="joint04"/>
                            <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_04"/><geom/></body>
                            <geom name="link4_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"/>
                            <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                            <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_04"/><geom/></body>

                            <!-- Joint 05: yaw -->
                            <body name="link5" pos="-0.35 0 0" childclass="yaw_joint">
                                <joint name="joint05"/>
                                <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_05"/><geom/></body>
                                <geom name="link5_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"/>
                                <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                                <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_05"/><geom/></body>

                                <!-- Joint 06: pitch -->
                                <body name="link6" pos="-0.35 0 0" childclass="pitch_joint">
                                    <joint name="joint06"/>
                                    <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_06"/><geom/></body>
                                    <geom name="link6_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"/>
                                    <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                                    <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_06"/><geom/></body>

                                    <!-- Joint 07: yaw -->
                                    <body name="link7" pos="-0.35 0 0" childclass="yaw_joint">
                                        <joint name="joint07"/>
                                        <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_07"/><geom/></body>
                                        <geom name="link7_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"/>
                                        <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                                        <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_07"/><geom/></body>

                                        <!-- Joint 08: pitch -->
                                        <body name="link8" pos="-0.35 0 0" childclass="pitch_joint">
                                            <joint name="joint08"/>
                                            <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_08"/><geom/></body>
                                            <geom name="link8_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"/>
                                            <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                                            <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_08"/><geom/></body>

                                            <!-- Joint 09: yaw -->
                                            <body name="link9" pos="-0.35 0 0" childclass="yaw_joint">
                                                <joint name="joint09"/>
                                                <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_09"/><geom/></body>
                                                <geom name="link9_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"/>
                                                <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                                                <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_09"/><geom/></body>

                                                <!-- Joint 10: pitch -->
                                                <body name="link10" pos="-0.35 0 0" childclass="pitch_joint">
                                                    <joint name="joint10"/>
                                                    <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_10"/><geom/></body>
                                                    <geom name="link10_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"/>
                                                    <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                                                    <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_10"/><geom/></body>

                                                    <!-- Joint 11: yaw (tail) -->
                                                    <body name="link11" pos="-0.35 0 0" childclass="yaw_joint">
                                                        <joint name="joint11"/>
                                                        <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_11"/><geom/></body>
                                                        <geom name="link11_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"/>
                                                        <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                                                        <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_11"/><geom/></body>
                                                    </body>
                                                </body>
                                            </body>
                                        </body>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <position name="actuator_joint01" joint="joint01"/>
        <position name="actuator_joint02" joint="joint02"/>
        <position name="actuator_joint03" joint="joint03"/>
        <position name="actuator_joint04" joint="joint04"/>
        <position name="actuator_joint05" joint="joint05"/>
        <position name="actuator_joint06" joint="joint06"/>
        <position name="actuator_joint07" joint="joint07"/>
        <position name="actuator_joint08" joint="joint08"/>
        <position name="actuator_joint09" joint="joint09"/>
        <position name="actuator_joint10" joint="joint10"/>
        <position name="actuator_joint11" joint="joint11"/>
    </actuator>

    <sensor>
        <!-- Joint position sensors -->
        <jointpos name="sensor_jointpos_joint01" joint="joint01"/>
        <jointpos name="sensor_jointpos_joint02" joint="joint02"/>
        <jointpos name="sensor_jointpos_joint03" joint="joint03"/>
        <jointpos name="sensor_jointpos_joint04" joint="joint04"/>
        <jointpos name="sensor_jointpos_joint05" joint="joint05"/>
        <jointpos name="sensor_jointpos_joint06" joint="joint06"/>
        <jointpos name="sensor_jointpos_joint07" joint="joint07"/>
        <jointpos name="sensor_jointpos_joint08" joint="joint08"/>
        <jointpos name="sensor_jointpos_joint09" joint="joint09"/>
        <jointpos name="sensor_jointpos_joint10" joint="joint10"/>
        <jointpos name="sensor_jointpos_joint11" joint="joint11"/>

        <!-- IMU on head -->
        <gyro name="sensor_gyro" site="site_head"/>
        <accelerometer name="sensor_accelerometer" site="site_head"/>

        <!-- Actuator force sensors -->
        <actuatorfrc name="sensor_actuatorfrc_joint01" actuator="actuator_joint01"/>
        <actuatorfrc name="sensor_actuatorfrc_joint02" actuator="actuator_joint02"/>
        <actuatorfrc name="sensor_actuatorfrc_joint03" actuator="actuator_joint03"/>
        <actuatorfrc name="sensor_actuatorfrc_joint04" actuator="actuator_joint04"/>
        <actuatorfrc name="sensor_actuatorfrc_joint05" actuator="actuator_joint05"/>
        <actuatorfrc name="sensor_actuatorfrc_joint06" actuator="actuator_joint06"/>
        <actuatorfrc name="sensor_actuatorfrc_joint07" actuator="actuator_joint07"/>
        <actuatorfrc name="sensor_actuatorfrc_joint08" actuator="actuator_joint08"/>
        <actuatorfrc name="sensor_actuatorfrc_joint09" actuator="actuator_joint09"/>
        <actuatorfrc name="sensor_actuatorfrc_joint10" actuator="actuator_joint10"/>
        <actuatorfrc name="sensor_actuatorfrc_joint11" actuator="actuator_joint11"/>
    </sensor>
</mujoco>
