<mujoco model="soft_snake_4link">
    <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>

    <option integrator="Euler" timestep="0.002">
        <flag energy="enable" clampctrl="enable"/>
    </option>

    <size nconmax="500"/>

    <default>
        <geom conaffinity="0" condim="3" friction="1 0.05 0.00001" margin="0.01" density="600"/>
        <joint armature="0.001" damping="0" frictionloss="0.001"/>

        <default class="wheel">
            <joint axis="0 1 0" type="hinge" damping="0.2"/>
            <geom type="cylinder" fromto="0 0 0 0 0.025 0" size="0.05"
                  material="geom" rgba=".9 .9 .9 1" friction="1.25 1.0 0.0001"/>
        </default>

        <default class="link">
            <geom material="geom" rgba="0.8 0.7 .6 1"/>
            <joint pos="0 0 0" axis="0 0 1" type="hinge" limited="true" range="-90 90"/>
        </default>

        <position ctrllimited="true" ctrlrange="-1.5 1.5"
                  forcelimited="true" forcerange="-20.0 20.0" kp="20" gear="1"/>
    </default>

    <asset>
        <texture builtin="gradient" height="100" rgb1="1 1 1" rgb2="0 0 0" type="skybox" width="100"/>
        <texture builtin="flat" height="128" mark="cross" markrgb="1 1 1" name="texgeom"
                 random="0.01" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" type="cube" width="128"/>
        <texture builtin="checker" height="100" name="texplane" rgb1="0 0 0"
                 rgb2="0.8 0.8 0.8" type="2d" width="100"/>
        <material name="MatPlane" reflectance="0.5" shininess="1" specular="1"
                  texrepeat="80 80" texture="texplane"/>
        <material name="geom" texture="texgeom" texuniform="true"/>
        <material name="MatTarget" rgba="1 0 0 1" reflectance="0.05" shininess="0.1" specular="0.1"/>
    </asset>

    <visual>
        <map znear="0.0625"/>
        <quality shadowsize="4096"/>
    </visual>

    <worldbody>
        <light cutoff="100" diffuse="1 1 1" dir="0 0 -1.3" directional="true"
               exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
        <geom name="floor" size="80 80 10" material="MatPlane" conaffinity="1"
              condim="3" pos="0 0 -0.1" rgba="0.8 0.9 0.8 1" type="plane"/>

        <!-- Goal marker -->
        <body name="goal" pos="2 0 0.1">
            <joint axis="1 0 0" name="goal_slider_x" type="slide"/>
            <joint axis="0 1 0" name="goal_slider_y" type="slide"/>
            <geom name="goal_geom" type="sphere" pos="0 0 0" size="0.15" material="MatTarget"/>
        </body>

        <!-- 4-link snake body -->
        <body name="link1" pos="0 0 0.0">
            <!-- Free body DOFs -->
            <joint axis="1 0 0" name="slider_x" type="slide"/>
            <joint axis="0 1 0" name="slider_y" type="slide"/>
            <joint axis="0 0 1" name="slider_z" type="slide"/>
            <joint pos="0 0 0" axis="1 0 0" name="hinge_x" type="hinge"/>
            <joint pos="0 0 0" axis="0 1 0" name="hinge_y" type="hinge"/>
            <joint pos="0 0 0" axis="0 0 1" name="hinge_z" type="hinge"/>

            <!-- Head link body and wheels -->
            <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_0"/><geom/></body>
            <geom name="head" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"
                  material="geom" rgba="0.8 0.7 .6 1"/>
            <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
            <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_0"/><geom/></body>

            <site name="site_head" pos="-0.175 0 0.0" type="box" size=".01 .01 .01"/>

            <camera name="track_top" mode="trackcom" pos="0 0 5" euler="0 0 0"/>
            <camera name="track_side" mode="trackcom" pos="0 -4 6" euler="30 0 0"/>

            <!-- Link 2 -->
            <body name="link2" pos="-0.35 0 0" childclass="link">
                <joint name="joint01"/>
                <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_1"/><geom/></body>
                <geom name="link2_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"
                      material="geom" rgba="0.8 0.7 .6 1"/>
                <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_1"/><geom/></body>

                <!-- Link 3 -->
                <body name="link3" pos="-0.35 0 0" childclass="link">
                    <joint name="joint02"/>
                    <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_2"/><geom/></body>
                    <geom name="link3_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"
                          material="geom" rgba="0.8 0.7 .6 1"/>
                    <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                    <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_2"/><geom/></body>

                    <!-- Link 4 (tail) -->
                    <body name="link4" pos="-0.35 0 0" childclass="link">
                        <joint name="joint03"/>
                        <body pos="-0.175 0.05 -0.05" childclass="wheel"><joint name="wheel_l_3"/><geom/></body>
                        <geom name="link4_geom" pos="-0.175 0 0" size="0.125 0.05 0.05" type="box"
                              material="geom" rgba="0.8 0.7 .6 1"/>
                        <geom fromto="-0.30 0 0 -0.05 0 0" size="0.05" type="capsule" rgba="1.0 0.0 0.0 1"/>
                        <body pos="-0.175 -0.075 -0.05" childclass="wheel"><joint name="wheel_r_3"/><geom/></body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <position name="actuator_joint01" joint="joint01"/>
        <position name="actuator_joint02" joint="joint02"/>
        <position name="actuator_joint03" joint="joint03"/>
    </actuator>

    <sensor>
        <actuatorfrc name="sensor_frc_joint01" actuator="actuator_joint01"/>
        <actuatorfrc name="sensor_frc_joint02" actuator="actuator_joint02"/>
        <actuatorfrc name="sensor_frc_joint03" actuator="actuator_joint03"/>
        <velocimeter name="sensor_velocimeter" site="site_head"/>
        <gyro name="sensor_gyro" site="site_head"/>
    </sensor>
</mujoco>
